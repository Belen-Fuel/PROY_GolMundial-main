<?xml version="1.0" encoding="UTF-8"?>

<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="
                 https://jakarta.ee/xml/ns/persistence
                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="GolMundialPU"
                      transaction-type="JTA">

        <!-- Datasource configurado en WildFly -->
        <jta-data-source>java:/jdbc/GolMundialDS</jta-data-source>

        <!-- Detecta automáticamente todas las clases anotadas con @Entity -->
        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <properties>

            <!--
                Crea las tablas que no existan y actualiza su estructura.
                No elimina los datos existentes.
            -->
            <property
                    name="hibernate.hbm2ddl.auto"
                    value="update"/>

            <!-- Mostrar las consultas SQL en la consola de WildFly -->
            <property
                    name="hibernate.show_sql"
                    value="true"/>

            <property
                    name="hibernate.format_sql"
                    value="true"/>

            <!-- Manejo interno de fechas en UTC -->
            <property
                    name="hibernate.jdbc.time_zone"
                    value="UTC"/>

        </properties>

    </persistence-unit>

</persistence>
